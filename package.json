{
  "name": "sohmnamp",
  "version": "4.0.4",
  "description": "SOHMNAMP — Immersive Cosmic Audio Visualizer",
  "main": "main.js",
  "author": "SOHMNAMP",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:mac:dmg": "node scripts/build-local-dmg.cjs",
    "build:mac:arm": "electron-builder --mac --arm64",
    "build:mac:intel": "electron-builder --mac --x64",
    "build:mac:universal": "electron-builder --mac --universal",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "release:mac": "electron-builder --mac --publish always",
    "release:win": "electron-builder --win --publish always",
    "build:mas": "electron-builder --mac mas --universal",
    "build:mas:dev": "electron-builder --mac mas-dev --universal",
    "verify:mas": "node scripts/verify-mas-build.cjs"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "dotenv": "^17.4.2",
    "electron": "42.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.sohmna.sohmnamp",
    "productName": "SOHMNAMP",
    "buildVersion": "4.0.8",
    "copyright": "Copyright © 2026 SOHMNAMP",
    "afterPack": "scripts/strip-xattrs.cjs",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "video-player.html",
      "main.js",
      "preload.js",
      "README.html",
      "assets/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "asarUnpack": [
      "assets/speech_helper.py",
      "assets/vosk-model/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "sohmnacode",
      "repo": "sohmnamp",
      "releaseType": "release"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.music",
      "darkModeSupport": true,
      "minimumSystemVersion": "10.13.6",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "identity": "Lawrence Ligad Jr (5S2MSRJ378)",
      "preAutoEntitlements": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "SOHMNAMP uses your camera to detect hand gestures for controlling playback.",
        "NSMicrophoneUsageDescription": "SOHMNAMP uses your microphone for voice commands and audio broadcast.",
        "NSSpeechRecognitionUsageDescription": "SOHMNAMP uses speech recognition to understand voice commands for controlling playback.",
        "NSDocumentsFolderUsageDescription": "SOHMNAMP reads music files you select from your Documents folder.",
        "ElectronTeamID": "5S2MSRJ378"
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "mas",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "mas": {
      "type": "distribution",
      "category": "public.app-category.music",
      "entitlements": "entitlements.mas.plist",
      "entitlementsInherit": "entitlements.mas.inherit.plist",
      "hardenedRuntime": true,
      "preAutoEntitlements": false,
      "provisioningProfile": "embedded.provisionprofile",
      "identity": "Lawrence Ligad Jr (5S2MSRJ378)",
      "asarUnpack": [],
      "files": [
        "index.html",
        "video-player.html",
        "main.js",
        "preload.js",
        "README.html",
        "assets/**/*",
        "!assets/speech_helper.py",
        "!assets/speech_helper",
        "!assets/speech_helper 2",
        "!assets/speech_helper 2.py",
        "!assets/vosk-model/**/*",
        "node_modules/electron-updater/**/*"
      ]
    },
    "masDev": {
      "type": "development",
      "provisioningProfile": "embedded.dev.provisionprofile"
    },
    "dmg": {
      "sign": false,
      "iconSize": 120,
      "contents": [
        {
          "x": 180,
          "y": 220
        },
        {
          "x": 480,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 660,
        "height": 440
      },
      "title": "SOHMNAMP Installer"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Audio"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SOHMNAMP",
      "deleteAppDataOnUninstall": false
    }
  }
}
